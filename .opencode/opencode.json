{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "innfo-mcp": {
      "type": "local",
      "command": ["node", "packages/innfo-mcp/dist/server.js"],
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/.next/**",
      "**/coverage/**",
      "**/.git/**"
    ]
  }
}
